server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }
    listen {
        type = acct
        ipaddr = *
        port = 1813
    }
    authorize {
        rest 
        if (ok) {
            update control {
                Auth-Type := REST
            }
        }
    }
    authenticate {
        Auth-Type REST {
            rest
        }
    }
    accounting {
        rest
    }
    post-auth {
        Post-Auth-Type REJECT {
            attr_filter.access_reject
        }
    }
}